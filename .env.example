APP_NAME=COSTFLOW
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Asia/Kuala_Lumpur

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------
# Database — SQLite locally, MySQL in production.
# For production set DB_CONNECTION=mysql and fill the block below.
# ---------------------------------------------------------------
DB_CONNECTION=sqlite

# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=costflow
# DB_USERNAME=costflow
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ---------------------------------------------------------------
# Mail — Brevo transactional API
# Get the key at https://app.brevo.com/settings/keys/api
# Set MAIL_MAILER=log to print emails to storage/logs/laravel.log instead.
# ---------------------------------------------------------------
MAIL_MAILER=brevo
BREVO_API_KEY=
MAIL_LOG_CHANNEL=mail
MAIL_FROM_ADDRESS="costflow@coursesme.com"
# Literal, not "${APP_NAME}": APP_NAME also derives the session cookie name.
MAIL_FROM_NAME="Cost Flow"

# ---------------------------------------------------------------
# COSTFLOW policy
# ---------------------------------------------------------------
COSTFLOW_EMAIL_DOMAIN=bpe.com.my
COSTFLOW_MAX_LOGIN_ATTEMPTS=3
COSTFLOW_LOCK_MINUTES=5
COSTFLOW_IDLE_MINUTES=30
COSTFLOW_OTP_TTL_MINUTES=10
COSTFLOW_OTP_MAX_ATTEMPTS=5
COSTFLOW_NOTIFY_WORKFLOW=true
